rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    function isValidMovie(data) {
      return data.keys().hasAll(['tmdbId', 'title', 'streamLink'])
        && data.tmdbId is string && data.tmdbId.size() <= 100
        && data.title is string && data.title.size() <= 200
        && data.streamLink is string && data.streamLink.size() <= 1000;
    }

    match /movies/{movieId} {
      allow read: if true; // Public access for viewing movies
      allow create: if isSignedIn() 
        && isValidId(movieId) 
        && isValidMovie(incoming());
      allow update: if isSignedIn()
        && isValidMovie(incoming());
      allow delete: if isSignedIn();
    }
  }
}
